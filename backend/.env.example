# ── Backend Environment (server-side only) ────────────────
# This file is NEVER bundled into client JS. It stays on the server.

# OpenRouter API key — set to enable real LLM mode (omit for mock mode)
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Internal microservice URLs (server-to-server only)
ONTOLOGY_SERVICE_URL=http://localhost:8084
DATAHUB_SERVICE_URL=http://localhost:8085

# PostgreSQL — must match the Dagster backend's bpmn_catalog DB
DATABASE_URL=postgresql+asyncpg://iagent:iagent@localhost:5432/iagent

# Dagster Webserver — for GraphQL workspace reload
DAGSTER_WEBSERVER_URL=http://localhost:3000
