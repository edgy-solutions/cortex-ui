# ── Frontend Environment ──────────────────────────────────
# This file is read by Vite. ONLY VITE_* vars are bundled into client JS.
# NEVER put secrets or internal service URLs here.
VITE_API_URL=http://localhost:8000
VITE_KEYCLOAK_REALM_URL=http://localhost:8080/realms/cortex
VITE_KEYCLOAK_CLIENT_ID=cortex-ui
VITE_NO_AUTH=false
